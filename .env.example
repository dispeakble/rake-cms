# Database — supports both PostgreSQL and MariaDB/MySQL
# Postgres: DATABASE_URL=postgresql://user:password@localhost:5432/rake_cms
# MariaDB:  DATABASE_URL=mysql://user:password@localhost:3306/rake_cms
DATABASE_URL=postgresql://localhost:5432/rake_cms
DATABASE_DIALECT=postgresql

# Auth (Auth.js v5)
AUTH_SECRET=change-me-to-a-random-secret
AUTH_URL=http://localhost:3000

# Media Storage
# Local filesystem (dev): MEDIA_STORAGE=local
# S3 (prod):             MEDIA_STORAGE=s3
MEDIA_STORAGE=local
MEDIA_LOCAL_PATH=public/media
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Rake CMS"

# Google Places API (for Maps integration)
# Get a key at https://console.cloud.google.com/apis/credentials
# GOOGLE_PLACES_API_KEY=your_key_here

# Brave Search API (optional — for enriched image/review scraping)
# Get a free API key at https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=your_key_here
